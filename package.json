{
  "name": "ai-health-assistant-backend",
  "version": "1.0.0",
  "description": "Backend API for the AI Health Assistant — IBM GenAI & Cloud Internship Project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "health",
